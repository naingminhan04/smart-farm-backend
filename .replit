modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "HOST=127.0.0.1 PORT=3000 npm run dev"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "HOST=0.0.0.0 PORT=5000 node dist/index.js"]
build = ["bash", "-c", "npx prisma generate && npm run build"]

[userenv]

[userenv.shared]
APP_BASE_URL = "https://smart-farm-backend--naingminhan.replit.app"
SERVER_PORT = "4000"
