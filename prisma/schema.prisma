generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DoorState {
  id    Int    @id @default(autoincrement())
  state String
  createdAt DateTime @default(now())
}

model TempHumi {
  id          Int      @id @default(autoincrement())
  temperature Float?
  humidity    Float?
  updatedTime DateTime @default(now()) @map("updated_time")
}

model User {
  id      Int    @id @default(autoincrement())
  cardNum String @unique @map("card_num")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions             AdminSession[]
  identities           AdminIdentity[]
  acknowledgedAlerts   IntruderAlert[] @relation("IntruderAlertAcknowledgedBy")
  emergencyDialedAlerts IntruderAlert[] @relation("IntruderAlertEmergencyDialedBy")
}

model AdminIdentity {
  id              Int      @id @default(autoincrement())
  adminId         Int      @map("admin_id")
  provider        String
  providerSubject String   @map("provider_subject")
  email           String?
  createdAt       DateTime @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([adminId])
}

model AdminSession {
  id               String   @id @default(uuid())
  adminId          Int      @map("admin_id")
  refreshTokenHash String   @unique @map("refresh_token_hash")
  adminTokenVersion Int     @map("admin_token_version")
  createdAt        DateTime @default(now()) @map("created_at")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?  @map("user_agent")
  ip               String?  @map("ip")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model AdminOAuthState {
  id            String   @id
  provider      String
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")
  bootstrapToken String? @map("bootstrap_token")

  @@index([provider])
  @@index([expiresAt])
}

model AdminBootstrapToken {
  id        String   @id
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")

  @@index([expiresAt])
}

model IntruderAlert {
  id                  Int       @id @default(autoincrement())
  source              String    @default("laser-fence")
  message             String    @default("Intruder detected by laser fence.")
  detectedAt          DateTime  @default(now()) @map("detected_at")
  clearedAt           DateTime? @map("cleared_at")
  acknowledgedAt      DateTime? @map("acknowledged_at")
  acknowledgedById    Int?      @map("acknowledged_by_id")
  emergencyDialedAt   DateTime? @map("emergency_dialed_at")
  emergencyDialedById Int?      @map("emergency_dialed_by_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  acknowledgedBy   Admin? @relation("IntruderAlertAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  emergencyDialedBy Admin? @relation("IntruderAlertEmergencyDialedBy", fields: [emergencyDialedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([acknowledgedAt])
  @@index([emergencyDialedAt])
  @@index([acknowledgedById])
  @@index([emergencyDialedById])
}
