SUPABASE_DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DATABASE_URL="postgresql://user:password@host:5432/database"
PORT=3000
HOST=127.0.0.1
ESP_WIFI_SSID="YourWiFiSSID"
ESP_WIFI_PASSWORD="YourWiFiPassword"
APP_BASE_URL="http://localhost:3000"

# Admin auth (required to write /cards)
# Use a long random secret (32+ chars). Example generation (bash): `openssl rand -base64 48`
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
# Access token lifetime (seconds or 15m/1h/7d)
JWT_ACCESS_TTL="15m"
# Refresh token lifetime (seconds or 15m/1h/7d)
JWT_REFRESH_TTL="30d"
# One-time bootstrap token to create the very first admin (POST /api/admin/setup)
ADMIN_SETUP_TOKEN="REPLACE_WITH_LONG_RANDOM_SETUP_TOKEN"
