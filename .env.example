# --- Database (Supabase Postgres) ---
# Pooler (port 6543) — used at runtime
SUPABASE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Direct (port 5432) — used by `prisma migrate`
SUPABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Optional fallback if SUPABASE_DATABASE_URL isn't set
DATABASE_URL=

# --- Admin auth (JWT) ---
JWT_SECRET=replace-with-a-32+char-random-string
ADMIN_SETUP_TOKEN=replace-with-a-one-time-setup-token
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional allowlist for admin OAuth sign-in (comma-separated emails).
# Recommended for extra safety once an admin already exists.
ADMIN_OAUTH_ALLOWED_EMAILS=

# --- URLs ---
# Frontend (used for CORS + post-login redirect target)
FRONTEND_URL=https://smart-farm-system.netlify.app
# Public backend URL (used to build OAuth callback URLs)
APP_BASE_URL=https://smart-farm-backend--naingminhan.replit.app

# --- Server ---
PORT=3000
HOST=127.0.0.1
